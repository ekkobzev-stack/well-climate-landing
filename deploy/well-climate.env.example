# Create /etc/well-climate/well-climate.env on the server with mode 600.
TELEGRAM_PUBLIC_URL=https://t.me/your_username
TELEGRAM_BOT_TOKEN=replace_on_server_only
TELEGRAM_CHAT_ID=replace_on_server_only
YANDEX_METRIKA_ID=replace_with_counter_id
CRM_INTAKE_URL=http://127.0.0.1:3080/api/intake/website
CRM_INTAKE_SECRET=replace_on_server_only_with_32_or_more_characters
# Optional: add a verified team photo later, for example /team.webp
TEAM_IMAGE_URL=
